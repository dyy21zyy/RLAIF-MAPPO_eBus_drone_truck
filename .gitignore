# Python caches and local environments
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Generated runtime artifacts
logs/*
!logs/.gitkeep
outputs/*
!outputs/.gitkeep
checkpoints/*
!checkpoints/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Editor and OS metadata
.DS_Store
.idea/
.vscode/
data/preference/*
!data/preference/.gitkeep
