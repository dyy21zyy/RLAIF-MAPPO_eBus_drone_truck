# Python caches and local environments
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Generated runtime artifacts
logs/*
!logs/.gitkeep
outputs/*
!outputs/.gitkeep
checkpoints/*
!checkpoints/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Editor and OS metadata
.DS_Store
.idea/
.vscode/
# Stage 4 preference-generation artifacts (keep local, never commit)
data/preference/*.jsonl
data/preference/*.json
data/preference/*.csv
data/preference/*.npy
data/preference/*.pt
!data/preference/.gitkeep

# Experiment outputs and model checkpoints
results/
runs/
checkpoints/
*.pt
*.pth
*.ckpt
